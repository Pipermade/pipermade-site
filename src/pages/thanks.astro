---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Thank you — Pipermade · Madison, WI"
  description="Thanks for reaching out to Pipermade. We respond to every inquiry within two business days."
>
  <section style="padding:clamp(80px,15vh,170px) 0;text-align:center">
    <div class="wrap">
      <span class="eyebrow">Inquiry received</span>
      <h1 style="font-size:clamp(34px,5vw,58px);margin:16px 0 16px">Thank you — talk soon.</h1>
      <p style="max-width:48ch;margin:0 auto 30px;color:var(--ink-soft);font-size:18px">
        Your inquiry is on its way to us. We read every message and respond within two business days.
      </p>
      <div class="hero-ctas" style="justify-content:center">
        <a class="btn" href="/">Back to home</a>
        <a class="quiet-link" href="/work">See selected work</a>
      </div>
    </div>
  </section>
</Layout>
