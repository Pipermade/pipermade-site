---
// TEMPORARY wordmark comparison. Delete once chosen.
import { Image } from 'astro:assets';
import logo from '../assets/pipermade-logo.png';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wordmark options</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sorts+Mill+Goudy:ital@0;1&family=Karla:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root{--linen:#EDEDD9;--paper:#F7F5E6;--green:#536143}
    body{font-family:'Karla',sans-serif;background:var(--linen);color:#262F1E;margin:0;padding:48px}
    h1{font-family:'Sorts Mill Goudy',serif;font-weight:400;font-size:24px;margin-bottom:6px}
    .sub{color:#8a7f6a;margin-bottom:40px}
    .opt{background:var(--paper);border:1px solid #ddd;border-radius:10px;padding:34px 40px;margin-bottom:26px;max-width:760px}
    .tag{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#B0813A;font-weight:600;margin-bottom:20px}
    .lockup{display:inline-flex;align-items:center;gap:10px;color:var(--green)}
    .lockup .mark{height:2.3em;width:auto;flex:none}
    .wm{font-family:'Sorts Mill Goudy',serif;font-size:34px;letter-spacing:.01em;line-height:1}
    .wm.italic{font-style:italic}
    .small{margin-top:20px;font-size:22px}
  </style>
</head>
<body>
  <h1>Two wordmark options</h1>
  <p class="sub">The hummingbird stays the same — just pick the lettering. Reply "Option 1" or "Option 2".</p>

  <div class="opt">
    <div class="tag">Option 1 · all upright</div>
    <div class="lockup"><Image class="mark" src={logo} alt="" widths={[80,160,240]} sizes="46px" /><span class="wm">Pipermade</span></div>
    <div class="lockup small"><Image class="mark" src={logo} alt="" widths={[80,160,240]} sizes="46px" /><span class="wm">Pipermade</span></div>
  </div>

  <div class="opt">
    <div class="tag">Option 2 · all italic</div>
    <div class="lockup"><Image class="mark" src={logo} alt="" widths={[80,160,240]} sizes="46px" /><span class="wm italic">Pipermade</span></div>
    <div class="lockup small"><Image class="mark" src={logo} alt="" widths={[80,160,240]} sizes="46px" /><span class="wm italic">Pipermade</span></div>
  </div>
</body>
</html>
