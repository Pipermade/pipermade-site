---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../assets/pipermade-logo.png';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pipermade — Custom Cabinetry, Built-ins & Furniture · Madison, WI',
  description = 'Pipermade designs and builds custom cabinetry, built-ins, and furniture by hand in Madison, Wisconsin. No CNC, no production line — just handwork.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.png" type="image/png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sorts+Mill+Goudy:ital@0;1&family=Karla:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <script is:inline>
    // Opt into the fade-in animation before first paint (no flash of hidden content),
    // and guarantee everything becomes visible even if the observer never fires.
    (function () {
      try {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduce) document.documentElement.classList.add('reveal-ready');
        setTimeout(function () {
          var els = document.querySelectorAll('.reveal');
          for (var i = 0; i < els.length; i++) els[i].classList.add('in');
        }, 1500);
      } catch (e) {}
    })();
  </script>
  <style is:global>
    /* click-to-call "Call" button, and keep both nav buttons visible on phones */
    .btn.ghost{background:transparent;color:var(--walnut)}
    .btn.ghost:hover{background:var(--walnut);color:var(--cream-on-dark);border-color:var(--walnut)}
    @media(max-width:720px){
      .nav-links{gap:12px}
      nav .nav-links li:nth-last-child(-n+2){display:block}
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a class="wordmark" href="/"><Image class="mark" src={logo} alt="" widths={[80, 160, 240]} sizes="46px" /><span class="wm-text">Piper<em>made</em></span></a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/work">Work</a></li>
        <li><a href="/#process">Process</a></li>
        <li><a href="/#about">About</a></li>
        <li><a class="btn ghost" href="tel:+16082399726">Call</a></li>
        <li><a class="btn" href="/#inquire">Start a project</a></li>
      </ul>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="wrap foot">
      <a class="wordmark" href="/"><Image class="mark" src={logo} alt="" widths={[80, 160, 240]} sizes="46px" /><span class="wm-text">Piper<em>made</em></span></a>
      <div class="links">
        <a href="/work">Work</a><a href="/#process">Process</a><a href="/#about">About</a><a href="/#inquire">Inquire</a>
      </div>
      <div style="font-size:13px">Madison, Wisconsin · <a href="tel:+16082399726">(608) 239-9726</a> · <a href="#">@pipermade</a></div>
    </div>
  </footer>

  <script>
    const els = Array.from(document.querySelectorAll('.reveal'));
    const show = (el) => el.classList.add('in');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reduce || !('IntersectionObserver' in window)) {
      els.forEach(show);
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            show(e.target);
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      els.forEach((el) => io.observe(el));

      // Backup for contexts where the observer doesn't fire on scroll
      // (e.g. some embedded/iframe previews): reveal anything in view directly.
      const sweep = () => {
        for (const el of els) {
          if (el.classList.contains('in')) continue;
          const r = el.getBoundingClientRect();
          if (r.top < window.innerHeight * 0.92 && r.bottom > 0) show(el);
        }
      };
      window.addEventListener('scroll', sweep, { passive: true });
      window.addEventListener('resize', sweep, { passive: true });
      window.addEventListener('load', sweep);
      sweep();
    }
  </script>
</body>
</html>
